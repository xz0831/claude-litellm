#!/usr/bin/env zsh

_AI_LITELLM_ENTRYPOINT="${0:A}"

_ai_litellm_resolve_fabric_home() {
  if [[ -n "${CLAUDE_LITELLM_ROOT:-}" ]]; then
    print -r -- "$CLAUDE_LITELLM_ROOT"
    return
  fi
  local script_dir="${_AI_LITELLM_ENTRYPOINT:h}"
  if [[ -f "$script_dir/../config/ai-litellm/lib.zsh" ]]; then
    print -r -- "${script_dir:h}"
    return
  fi
  if [[ -n "${AI_LITELLM_HOME:-}" ]]; then
    print -r -- "$AI_LITELLM_HOME"
    return
  fi
  print -r -- "${XDG_DATA_HOME:-$HOME/.local/share}/claude-litellm"
}

export AI_LITELLM_HOME="$(_ai_litellm_resolve_fabric_home)"

managed_manifest="$AI_LITELLM_HOME/install-manifest.json"
managed_lib="$AI_LITELLM_HOME/config/ai-litellm/lib.zsh"
managed_shell="$AI_LITELLM_HOME/config/claude-litellm/shell.zsh"
managed_verifier="$AI_LITELLM_HOME/scripts/verify-install.py"

_ai_litellm_external_python() {
  local directory candidate resolved
  local -a candidates
  candidates=(/opt/homebrew/bin/python3.13 /usr/local/bin/python3.13)
  for directory in ${(s/:/)PATH}; do
    [[ -n "$directory" ]] || directory=.
    candidates+=("$directory/python3.13")
  done
  for candidate in "${candidates[@]}"; do
    [[ -x "$candidate" && -f "$candidate" ]] || continue
    resolved="${candidate:A}"
    case "$resolved" in
      "$AI_LITELLM_HOME"|"$AI_LITELLM_HOME"/*) continue ;;
    esac
    if "$resolved" -I -B -S -c 'import sys; raise SystemExit(0 if sys.version_info[:2] == (3, 13) else 1)' \
      >/dev/null 2>&1; then
      print -r -- "$resolved"
      return 0
    fi
  done
  return 1
}

if [[ -e "$managed_manifest" || -L "$managed_manifest" ]]; then
  if [[ ! -f "$managed_manifest" || -L "$managed_manifest" || \
        ! -f "$managed_lib" || -L "$managed_lib" || \
        ! -f "$managed_shell" || -L "$managed_shell" || \
        ! -f "$managed_verifier" || -L "$managed_verifier" ]]; then
    echo "claude-litellm installation is damaged; refusing legacy helper fallback. Reinstall the package." >&2
    exit 1
  fi
  external_python="$(_ai_litellm_external_python)" || {
    echo "claude-litellm requires an external Python 3.13 integrity verifier; reinstall Python 3.13." >&2
    exit 1
  }
  # Do not execute a package-owned verifier until this tiny stdlib bootstrap
  # has matched its bytes to the manifest. The installed public launcher pins
  # that manifest's digest, closing the package-root trust loop for normal use.
  "$external_python" -I -B -S - "$managed_manifest" "$managed_verifier" \
    "$AI_LITELLM_HOME" "${CLAUDE_LITELLM_MANIFEST_SHA256:-}" <<'PY' || exit 1
import hashlib
import json
import os
import stat
import sys

manifest, verifier, prefix, pinned_manifest = sys.argv[1:]

def read_regular(path, required_mode=None):
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    fd = os.open(path, flags)
    try:
        info = os.fstat(fd)
        if not stat.S_ISREG(info.st_mode):
            raise OSError("not a regular file")
        if required_mode is not None and stat.S_IMODE(info.st_mode) != required_mode:
            raise OSError("unsafe file mode")
        chunks = []
        while chunk := os.read(fd, 1024 * 1024):
            chunks.append(chunk)
        return b"".join(chunks)
    finally:
        os.close(fd)

try:
    manifest_bytes = read_regular(manifest, 0o600)
    if pinned_manifest and hashlib.sha256(manifest_bytes).hexdigest() != pinned_manifest:
        raise ValueError("public launcher manifest pin mismatch")
    payload = json.loads(manifest_bytes.decode("utf-8"))
    expected = payload["packageFiles"]["scripts/verify-install.py"]
    verifier_bytes = read_regular(verifier)
except (OSError, ValueError, KeyError, TypeError):
    raise SystemExit("claude-litellm installation manifest is invalid; reinstall the package")
digest = hashlib.sha256(verifier_bytes).hexdigest()
if digest != expected:
    raise SystemExit("claude-litellm verifier digest mismatch; reinstall the package")
sys.argv = [verifier, "--prefix", prefix]
if pinned_manifest:
    sys.argv.extend(["--expect-manifest-sha256", pinned_manifest])
namespace = {"__name__": "__main__", "__file__": verifier}
exec(compile(verifier_bytes, verifier, "exec"), namespace)
PY
  source "$managed_lib"
  source "$managed_shell"
elif [[ -f "$managed_lib" && ! -L "$managed_lib" ]]; then
  source "$AI_LITELLM_HOME/config/ai-litellm/lib.zsh"
elif [[ -f "$HOME/.config/ai-litellm/lib.zsh" ]]; then
  source "$HOME/.config/ai-litellm/lib.zsh"
fi

if typeset -f claude-litellm >/dev/null 2>&1; then
  :
elif [[ -f "$managed_shell" && ! -L "$managed_shell" ]]; then
  source "$AI_LITELLM_HOME/config/claude-litellm/shell.zsh"
elif [[ -f "$HOME/.config/claude-litellm/shell.zsh" ]]; then
  source "$HOME/.config/claude-litellm/shell.zsh"
fi

if ! typeset -f claude-litellm >/dev/null 2>&1; then
  echo "claude-litellm shell helper is not available" >&2
  exit 1
fi

claude-litellm "$@"
