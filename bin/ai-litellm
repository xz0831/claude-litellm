#!/usr/bin/env zsh

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  source "$NVM_DIR/nvm.sh"
fi

_ai_litellm_resolve_fabric_home() {
  if [[ -n "${AI_LITELLM_HOME:-}" ]]; then
    print -r -- "$AI_LITELLM_HOME"
    return
  fi
  local script_dir="${0:A:h}"
  if [[ -f "$script_dir/../config/ai-litellm/lib.zsh" ]]; then
    print -r -- "${script_dir:h}"
    return
  fi
  print -r -- "${XDG_DATA_HOME:-$HOME/.local/share}/ai-litellm"
}

export AI_LITELLM_HOME="$(_ai_litellm_resolve_fabric_home)"

if [[ -f "$AI_LITELLM_HOME/config/ai-litellm/lib.zsh" ]]; then
  source "$AI_LITELLM_HOME/config/ai-litellm/lib.zsh"
elif [[ -f "$HOME/.config/ai-litellm/lib.zsh" ]]; then
  source "$HOME/.config/ai-litellm/lib.zsh"
fi

if ! typeset -f ai_litellm >/dev/null 2>&1; then
  echo "ai-litellm shared library is not available" >&2
  exit 1
fi

ai_litellm "$@"
