{
  "schemaVersion": 1,
  "name": "claude",
  "displayName": "Claude Code via OpenRouter Direct",
  "adapter": "claude-code",
  "command": "claude",
  "paths": {
    "home": "__AI_LITELLM_HOME__/state/claude-litellm",
    "settings": "__AI_LITELLM_HOME__/config/claude-litellm/settings.json",
    "configDir": "__AI_LITELLM_HOME__/state/claude-litellm/claude-config",
    "settingsArg": "__AI_LITELLM_HOME__/state/claude-litellm/overlay-settings.json",
    "settingsArgProxy": "__AI_LITELLM_HOME__/state/claude-litellm/overlay-settings-proxy.json"
  },
  "isolation": {
    "kind": "env-dir-var",
    "env": "CLAUDE_CONFIG_DIR",
    "sharedEnvironment": {
      "targetRoot": "__HOME__/.claude",
      "items": [
        "settings.json",
        "settings.local.json",
        "plugins",
        "skills",
        "keybindings.json",
        "CLAUDE.md"
      ]
    },
    "scrubEnv": [
      "CODEX_HOME",
      "OPENROUTER_API_KEY",
      "OPENAI_API_KEY",
      "OPENAI_API_BASE",
      "OPENAI_BASE_URL",
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_BASE_URL",
      "ANTHROPIC_AUTH_TOKEN",
      "ANTHROPIC_MODEL",
      "ANTHROPIC_DEFAULT_FABLE_MODEL",
      "ANTHROPIC_DEFAULT_OPUS_MODEL",
      "ANTHROPIC_DEFAULT_SONNET_MODEL",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME",
      "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME",
      "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME",
      "ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES",
      "ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES",
      "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES",
      "CLAUDE_CODE_ATTRIBUTION_HEADER",
      "CLAUDE_CODE_SUBAGENT_MODEL",
      "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY",
      "CLAUDE_CODE_SKIP_FAST_MODE_ORG_CHECK",
      "CLAUDE_CODE_AUTO_COMPACT_WINDOW",
      "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
      "GOOGLE_API_KEY",
      "GEMINI_API_KEY",
      "OLLAMA_HOST",
      "LITELLM_API_KEY",
      "LITELLM_MASTER_KEY",
      "CLAUDE_CODE_USE_BEDROCK",
      "CLAUDE_CODE_USE_VERTEX",
      "CLAUDE_CODE_SKIP_BEDROCK_AUTH",
      "CLAUDE_CODE_SKIP_VERTEX_AUTH",
      "ANTHROPIC_BEDROCK_BASE_URL",
      "ANTHROPIC_VERTEX_BASE_URL",
      "AWS_BEARER_TOKEN_BEDROCK",
      "ANTHROPIC_CUSTOM_HEADERS"
    ]
  },
  "provider": {
    "baseUrl": "https://openrouter.ai/api",
    "auth": {
      "mode": "env-value",
      "env": "ANTHROPIC_AUTH_TOKEN",
      "source": "openrouter-key"
    }
  },
  "models": {
    "mode": "tier-aliases",
    "tiers": [
      "fable",
      "opus",
      "sonnet",
      "haiku"
    ]
  },
  "adapterConfig": {
    "mode": "openrouter-direct",
    "emptyApiKeyEnv": "ANTHROPIC_API_KEY",
    "subagentModelEnv": "CLAUDE_CODE_SUBAGENT_MODEL",
    "fastModeOrgCheckEnv": "CLAUDE_CODE_SKIP_FAST_MODE_ORG_CHECK",
    "generatedSettings": {
      "enableWorkflows": true,
      "skipWorkflowUsageWarning": true,
      "permissions": {
        "defaultMode": "default"
      }
    },
    "attributionHeaderEnv": "CLAUDE_CODE_ATTRIBUTION_HEADER",
    "discoveryEnv": "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY",
    "baseUrlEnv": "ANTHROPIC_BASE_URL",
    "tierModelEnvPrefix": "ANTHROPIC_DEFAULT",
    "tierDisplayNameEnvPrefix": "ANTHROPIC_DEFAULT",
    "autoCompactWindowEnv": "CLAUDE_CODE_AUTO_COMPACT_WINDOW",
    "maxOutputTokensEnv": "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
    "outputReservation": {
      "default": 32000,
      "tokenizerHeadroom": 8192,
      "minimumInput": 32768
    },
    "reasoning": {
      "control": "intent",
      "source": "claude-code-effort",
      "effort": "auto",
      "wire": "tier/model+optional-cli-flag:--effort",
      "confidence": "inferred",
      "notes": "Claude Code tier selection can affect effort defaults; explicit efforts are passed with --effort."
    },
    "context": {
      "surface": "claude-litellm",
      "budgetKind": "compact-threshold+router",
      "authLane": "litellm-master-key",
      "confidence": "local-config"
    }
  }
}
