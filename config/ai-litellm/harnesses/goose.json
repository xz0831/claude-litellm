{
  "schemaVersion": 1,
  "name": "goose",
  "displayName": "goose via LiteLLM",
  "adapter": "env-injector",
  "command": "goose",
  "paths": {
    "home": "__HOME__/.config/goose-litellm"
  },
  "isolation": {
    "kind": "env-dir-var",
    "env": "GOOSE_PATH_ROOT",
    "scrubEnv": [
      "OPENROUTER_API_KEY",
      "OPENAI_API_KEY",
      "OPENAI_API_BASE",
      "OPENAI_BASE_URL",
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_BASE_URL",
      "ANTHROPIC_AUTH_TOKEN",
      "GOOGLE_API_KEY",
      "GEMINI_API_KEY",
      "OLLAMA_HOST",
      "LITELLM_MASTER_KEY",
      "LITELLM_API_KEY",
      "CODEX_HOME",
      "CLAUDE_CONFIG_DIR",
      "OPENCODE_CONFIG",
      "OPENCODE_CONFIG_DIR",
      "GOOSE_CONTEXT_LIMIT",
      "GOOSE_MAX_TOKENS"
    ]
  },
  "provider": {
    "name": "litellm",
    "displayName": "LiteLLM",
    "baseUrl": "{{ai.baseUrl}}",
    "basePath": "/v1/chat/completions",
    "auth": {
      "mode": "env-value",
      "env": "LITELLM_API_KEY",
      "source": "litellm-master-key"
    }
  },
  "models": {
    "default": "gpt-5.4"
  },
  "adapterConfig": {
    "env": {
      "GOOSE_PROVIDER": "litellm",
      "GOOSE_MODEL": "{{model}}",
      "GOOSE_CONTEXT_LIMIT": "{{reservation.effectiveInput}}",
      "GOOSE_MAX_TOKENS": "{{reservation.output}}",
      "LITELLM_HOST": "{{provider.baseUrl}}",
      "LITELLM_BASE_PATH": "{{provider.basePath}}",
      "GOOSE_DISABLE_SESSION_NAMING": "true"
    },
    "outputReservation": {
      "default": 32000,
      "tokenizerHeadroom": 8192,
      "minimumInput": 32768
    },
    "reasoning": {
      "control": "none",
      "source": "none",
      "wire": "provider-default",
      "confidence": "unknown"
    },
    "context": {
      "surface": "goose-litellm",
      "budgetKind": "display/compact+router",
      "authLane": "litellm-master-key",
      "confidence": "local-config"
    },
    "subcommands": [
      "run",
      "session",
      "configure",
      "update",
      "mcp",
      "recipe",
      "help"
    ]
  }
}
