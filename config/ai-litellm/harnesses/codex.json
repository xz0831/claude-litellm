{
  "schemaVersion": 1,
  "name": "codex",
  "displayName": "Codex via LiteLLM",
  "adapter": "codex-cli",
  "command": "codex",
  "paths": {
    "home": "__FABRIC_HOME__/state/codex-litellm",
    "settings": "__FABRIC_HOME__/config/codex-litellm/settings.json",
    "codexHome": "__FABRIC_HOME__/state/codex-litellm/codex-home",
    "config": "__FABRIC_HOME__/state/codex-litellm/codex-home/config.toml",
    "modelCatalog": "__FABRIC_HOME__/state/codex-litellm/model-catalog.json"
  },
  "isolation": {
    "kind": "env-dir-var",
    "env": "CODEX_HOME",
    "scrubEnv": [
      "OPENROUTER_API_KEY",
      "OPENAI_API_KEY",
      "OPENAI_API_BASE",
      "OPENAI_BASE_URL",
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_BASE_URL",
      "ANTHROPIC_AUTH_TOKEN",
      "GOOGLE_API_KEY",
      "GEMINI_API_KEY",
      "OLLAMA_HOST",
      "LITELLM_API_KEY",
      "LITELLM_MASTER_KEY",
      "ANTHROPIC_DEFAULT_FABLE_MODEL",
      "ANTHROPIC_DEFAULT_OPUS_MODEL",
      "ANTHROPIC_DEFAULT_SONNET_MODEL",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME",
      "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME",
      "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME",
      "ANTHROPIC_MODEL_DISPLAY_NAME_FABLE",
      "ANTHROPIC_MODEL_DISPLAY_NAME_OPUS",
      "ANTHROPIC_MODEL_DISPLAY_NAME_SONNET",
      "ANTHROPIC_MODEL_DISPLAY_NAME_HAIKU",
      "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY",
      "CLAUDE_CONFIG_DIR"
    ]
  },
  "provider": {
    "name": "litellm",
    "displayName": "LiteLLM",
    "baseUrl": "{{ai.apiBaseUrl}}",
    "auth": {
      "mode": "env-name",
      "env": "LITELLM_MASTER_KEY",
      "source": "litellm-master-key"
    },
    "wireApi": "responses",
    "supportsWebsockets": false
  },
  "models": {
    "default": "gpt-5.5",
    "catalogBaseSlug": "gpt-5.4-mini",
    "localCatalogEntries": [
      {
        "slug": "Gemma4-12B-omlx",
        "displayName": "Gemma 4 12B (omlx)",
        "description": "Local Gemma 4 12B 4-bit served by oMLX through LiteLLM.",
        "priority": 90,
        "defaultReasoningLevel": "low"
      }
    ]
  },
  "adapterConfig": {
    "modelReasoningSummary": "none",
    "modelSupportsReasoningSummaries": false,
    "approvalPolicy": "on-request",
    "sandboxMode": "workspace-write",
    "personality": "pragmatic",
    "modelReasoningEffort": "xhigh",
    "outputReservation": {
      "default": 32000,
      "tokenizerHeadroom": 8192,
      "minimumInput": 32768
    },
    "reasoning": {
      "control": "intent",
      "source": "codex-model_reasoning_effort",
      "effort": "xhigh",
      "wire": "config:model_reasoning_effort",
      "confidence": "configured"
    },
    "context": {
      "surface": "codex-litellm",
      "budgetKind": "harness-catalog+router",
      "authLane": "litellm-master-key",
      "confidence": "local-config"
    },
    "features": {
      "apps": false,
      "multi_agent": false,
      "plugins": false,
      "plugin_sharing": false
    },
    "shellEnvironmentPolicy": {
      "inherit": "core"
    },
    "projectTrust": {
      "__HOME__": "untrusted"
    },
    "availabilityNux": {
      "gpt-5.5": 4
    },
    "subcommands": [
      "exec",
      "review",
      "login",
      "logout",
      "mcp",
      "plugin",
      "mcp-server",
      "app-server",
      "remote-control",
      "app",
      "completion",
      "update",
      "doctor",
      "sandbox",
      "debug",
      "apply",
      "resume",
      "archive",
      "unarchive",
      "fork",
      "cloud",
      "exec-server",
      "features",
      "help"
    ]
  }
}
