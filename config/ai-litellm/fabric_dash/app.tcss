/* ── status color system ───────────────────────────────────────────────
   green  = ok / healthy            ($success)
   amber  = needs attention / gate  ($warning)
   red    = error / destructive     ($error)
   Applied inline via Rich tags in app.py; the classes below let widgets
   opt into the same palette so the system stays consistent. */
.ok   { color: $success; }
.warn { color: $warning; }
.bad  { color: $error; }

/* ── layout ────────────────────────────────────────────────────────────*/
#status {
    dock: top;
    height: 1;
    background: $panel;
    color: $text;
    padding: 0 1;
}
#body { height: 1fr; }

Tree {
    width: 28;
    border-right: solid $primary;
    padding: 0 1;
}

#content { width: 1fr; padding: 0 1; }

#harness-table {
    width: 1fr;
    height: 1fr;
}
/* Header row hierarchy: bold + accent, distinct from body. */
#harness-table > .datatable--header {
    text-style: bold;
    color: $secondary;
}
#harness-table > .datatable--cursor {
    background: $primary;
    color: $text;
}

#results {
    height: 8;
    border-top: solid $primary;
    padding: 0 1;
}

/* ── confirm modal: the primary safety surface ─────────────────────────*/
ConfirmModal {
    align: center middle;
    background: $background 60%;   /* dim the app behind the gate */
}

#confirm-box {
    width: 64;
    height: auto;
    padding: 1 2;
    background: $surface;
    border: round $warning;        /* restart grade: amber */
}
#confirm-box.destructive {
    border: round $error;          /* destructive grade: red */
}

#confirm-title {
    text-style: bold;
    color: $warning;
    margin-bottom: 1;
}
#confirm-box.destructive #confirm-title {
    color: $error;
}

#confirm-msg {
    color: $text;
    margin-bottom: 1;
}

#confirm-buttons {
    height: auto;
    align-horizontal: right;
}
#confirm-buttons Button {
    margin-left: 2;
}
