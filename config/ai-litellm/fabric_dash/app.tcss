/* ── status color system ───────────────────────────────────────────────
   green  = ok / healthy            ($success)
   amber  = needs attention / gate  ($warning)
   red    = error / destructive     ($error)
   Applied inline via Rich tags in app.py; the classes below let widgets
   opt into the same palette so the system stays consistent. */
.ok   { color: $success; }
.warn { color: $warning; }
.bad  { color: $error; }

/* ── layout ────────────────────────────────────────────────────────────*/
#status {
    dock: top;
    height: 1;
    background: $panel;
    color: $text;
    padding: 0 1;
}
#body { height: 1fr; }

Tree {
    width: 30;
    border: round $primary 50%;
    border-title-color: $secondary;
    padding: 0 1;
}

#content {
    width: 1fr;
    height: 1fr;
    border: round $primary 50%;
    border-title-color: $secondary;
    padding: 0 1;
}

#data-table {
    width: 1fr;
    height: 1fr;
    border: round $primary 50%;
    border-title-color: $secondary;
    /* No padding: 0 1 here — DataTable manages its own cell spacing internally. */
}
/* Header row hierarchy: bold + accent, distinct from body. */
#data-table > .datatable--header {
    text-style: bold;
    color: $secondary;
}
#data-table > .datatable--cursor {
    background: $primary;
    color: $text;
}

#results {
    height: 8;
    border: round $primary 50%;
    border-title-color: $secondary;
    padding: 0 1;
}

/* Color-graded action bar (see footer.py). Keys are tinted by safety grade
   inline; border-top makes it read as a distinct action strip rather than
   a faint status line. height: 2 absorbs the border row so bar text is not
   clipped (the border itself takes 1 row, text takes 1 row). */
#footer {
    dock: bottom;
    height: 2;
    background: $panel;
    color: $text;
    border-top: solid $primary 50%;
    padding: 0 1;
}

/* ── help overlay: full keymap, read-only, dismissed by ?/esc/q ────────*/
HelpOverlay {
    align: center middle;
    background: $background 60%;
}

#help-body {
    width: 60;
    padding: 1 2;
    background: $surface;
    border: round $primary;
}

/* ── confirm modal: the primary safety surface ─────────────────────────*/
ConfirmModal {
    align: center middle;
    background: $background 60%;   /* dim the app behind the gate */
}

#confirm-box {
    width: 64;
    height: auto;
    padding: 1 2;
    background: $surface;
    border: round $warning;        /* guarded grades: amber gate */
}

#confirm-title {
    text-style: bold;
    color: $warning;
    margin-bottom: 1;
}

#confirm-msg {
    color: $text;
    margin-bottom: 1;
}

#confirm-buttons {
    height: auto;
    align-horizontal: right;
}
#confirm-buttons Button {
    margin-left: 2;
}

/* ── command palette: fuzzy filter + arg-mode ───────────────────────────*/
CommandPalette { align: center middle; background: $background 60%; }
#palette-box { width: 70; height: auto; max-height: 80%; padding: 1 2; background: $surface; border: round $primary; }
#palette-input { margin-bottom: 1; }
#palette-list { height: auto; max-height: 16; }

/* ── effort selector: reasoning effort picker ───────────────────────────*/
EffortSelector { align: center middle; background: $background 60%; }
#effort-box { width: 40; height: auto; padding: 1 2; background: $surface; border: round $primary; }
#effort-title { margin-bottom: 1; color: $secondary; }
#effort-list { height: auto; max-height: 12; }

/* ── key-set modal: provider picker → masked secret (amber = writes a credential) ──*/
KeySetModal { align: center middle; background: $background 60%; }
#key-box { width: 50; height: auto; padding: 1 2; background: $surface; border: round $warning; }
#key-title { margin-bottom: 1; color: $secondary; }
#key-list { height: auto; max-height: 10; }
